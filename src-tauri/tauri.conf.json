{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tax Cross Check",
  "version": "0.1.0",
  "identifier": "com.rajan.taxcrosscheck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tax Cross Check",
        "width": 1280,
        "height": 920,
        "minWidth": 980,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
